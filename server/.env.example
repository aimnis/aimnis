# Copy to .env (gitignored). Real secrets are injected at deploy, never committed.
# All settings use the AIMNIS_ prefix (see aimnis/config.py for the full list + defaults).

# --- Core ---
AIMNIS_DATABASE_URL=postgresql://aimnis:aimnis@localhost:5432/aimnis
AIMNIS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AIMNIS_EMBEDDING_DIM=384
AIMNIS_QUOTA_KEY_LABEL=primary-free

# --- Live-fallback search: ordered provider chain (brave → tavily → exa → searxng) ---
# "auto" tries every provider with a key set, in preference order, then the keyless
# SearXNG floor. Set to a specific name (brave|tavily|exa|searxng) to try that first.
# Each provider is skipped unless its key is present, so a free tier that runs dry
# rolls onto the next instead of failing.
AIMNIS_SEARCH_BACKEND=auto
AIMNIS_SEARXNG_URL=http://localhost:8888
# AIMNIS_BRAVE_API_KEY=
# AIMNIS_TAVILY_API_KEY=
# AIMNIS_EXA_API_KEY=

# --- Citation redirect (optional, off unless a signing secret is set) ---
# Route cited source links through a signed /r/<token> redirect that logs an
# AGGREGATE click (entry + source + host + time — never IP/UA/user) to feed
# ranking, then 302s to the source. Fail-closed: no secret ⇒ raw URLs, no routing.
# Self-host: point the base at your OWN gateway so clicks stay on your box.
# AIMNIS_CITATION_SIGNING_SECRET=
# AIMNIS_CITATION_PUBLIC_BASE_URL=https://api.aimnis.org

# --- LLM distillation of cache misses (OpenRouter :free) ---
# Optional: without a key the service degrades to raw snippets and spends zero quota.
# AIMNIS_OPENROUTER_API_KEY=
